                  "valueMarkdown": "Comment"
                }
              ]
            }
          ]
        },
        "definition": "Toelichting over het telefoonnummer en over het gebruik ervan. Aangegeven kan bijvoorbeeld worden dat het een afdelingsnummer is (bij zorgverleners) of dat de bereikbaarheid slecht gedurende een aangegeven deel van de dag mogelijk is.",
        "_definition": {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/translation",
              "extension": [
                {
                  "url": "lang",
                  "valueCode": "en-US"
                },
                {
                  "url": "content",
                  "valueMarkdown": "Explanation about the telephone number and how to use it. It can be indicated, for example, that it is a department number (for healthcare professionnels) or that availability by phone is only possible during a specified part of the day."
                }
              ]
            }
          ]
        },
        "min": 0,
        "max": "1",
